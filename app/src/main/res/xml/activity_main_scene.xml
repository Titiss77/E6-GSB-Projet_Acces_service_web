<?xml version="1.0" encoding="utf-8"?>
<MotionScene 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetEnd="@+id/end"
        motion:constraintSetStart="@id/start"
        motion:duration="1000">
       <KeyFrameSet>
       </KeyFrameSet>
    </Transition>

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@+id/textViewEntete"
            android:layout_width="185dp"
            android:layout_height="30dp"
            motion:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="0dp"
            motion:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="0dp"
            motion:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="55dp">
            <CustomAttribute
                motion:attributeName="textSize"
                motion:customDimension="8dp" />
        </Constraint>
        <Constraint
            android:layout_width="258dp"
            android:layout_height="34dp"
            motion:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="125dp"
            android:id="@+id/textViewDescription"
            motion:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="0dp"
            android:layout_marginLeft="0dp"
            motion:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="0dp"
            android:layout_marginRight="0dp" />
        <Constraint
            android:id="@+id/buttonEnvoyer"
            android:layout_width="125dp"
            android:layout_height="48dp"
            motion:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp"
            android:layout_marginRight="16dp"
            motion:layout_constraintTop_toBottomOf="@+id/textViewDescription"
            android:layout_marginTop="46dp"
            motion:layout_constraintStart_toEndOf="@+id/editTextDescription"
            android:layout_marginStart="9dp"
            android:layout_marginLeft="9dp" />
        <Constraint
            android:id="@+id/editTextFilmId"
            motion:layout_constraintEnd_toEndOf="parent"
            android:layout_width="245dp"
            android:layout_height="48dp"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="205dp"
            motion:layout_constraintHorizontal_bias="0.096" />
        <Constraint
            android:layout_width="380dp"
            android:layout_height="30dp"
            android:id="@+id/textViewFilmTitle"
            motion:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="0dp"
            motion:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="0dp"
            motion:layout_constraintTop_toBottomOf="@+id/editTextFilmId"
            android:layout_marginTop="55dp" />
        <Constraint
            android:layout_width="380dp"
            android:layout_height="200dp"
            android:id="@+id/textViewEpisodeId"
            motion:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="0dp"
            motion:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="0dp"
            motion:layout_constraintTop_toBottomOf="@+id/textViewFilmTitle"
            android:layout_marginTop="18dp" />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end"></ConstraintSet>
</MotionScene>